# Frontend env (Vite). Copy to `.env.local`.
#
# URL of the deployed/served lead-deep-dive edge function. When set, the AI
# Deep-Dive runs LIVE (Firecrawl + AI). When empty, it falls back to the
# built-in simulation so the app still runs with no backend.
#
# Local Supabase serve default:
#   VITE_DEEP_DIVE_URL=http://localhost:54321/functions/v1/lead-deep-dive
# Deployed:
#   VITE_DEEP_DIVE_URL=https://<project-ref>.supabase.co/functions/v1/lead-deep-dive
VITE_DEEP_DIVE_URL=

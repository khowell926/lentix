# Secrets for the lead-deep-dive edge function.
# Local: copy to .env and run `supabase functions serve lead-deep-dive --env-file supabase/functions/.env`
# Prod:  `supabase secrets set --env-file supabase/functions/.env`
# NEVER commit real keys. NEVER expose these to the browser.

# Firecrawl — web scraping + search (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM synthesis. Defaults target the Lovable AI Gateway (Gemini 2.5 Flash),
# matching the production Lentix stack. Any OpenAI-compatible endpoint works.
AI_API_KEY=your-ai-gateway-or-openai-compatible-key
# AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# AI_MODEL=google/gemini-2.5-flash
